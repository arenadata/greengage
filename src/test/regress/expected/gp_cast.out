-- Confirm that casting logic works recursively
explain (verbose)
select * from cst_int2
    join cst_int8 using(a)
    join cst_int4 using(a);
                                                            QUERY PLAN                                                            
----------------------------------------------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)  (cost=1436.00..26078558.40 rows=848213289 width=8)
   Output: cst_int8.a
   ->  Hash Join  (cost=1436.00..14769047.88 rows=282737763 width=8)
         Output: cst_int8.a
         Hash Cond: (cst_int2.a = cst_int4.a)
         ->  Hash Join  (cost=679.75..152833.85 rows=2936010 width=10)
               Output: cst_int2.a, cst_int8.a
               Hash Cond: (cst_int2.a = cst_int8.a)
               ->  Seq Scan on public.cst_int2  (cost=0.00..375.00 rows=34100 width=2)
                     Output: cst_int2.a
               ->  Hash  (cost=321.00..321.00 rows=28700 width=8)
                     Output: cst_int8.a
                     ->  Seq Scan on public.cst_int8  (cost=0.00..321.00 rows=28700 width=8)
                           Output: cst_int8.a
         ->  Hash  (cost=355.00..355.00 rows=32100 width=4)
               Output: cst_int4.a
               ->  Seq Scan on public.cst_int4  (cost=0.00..355.00 rows=32100 width=4)
                     Output: cst_int4.a
 Optimizer: Postgres-based planner
 Settings: optimizer = 'off', optimizer_enable_mergejoin = 'off', optimizer_enable_nljoin = 'off', optimizer_join_order = 'query'
(20 rows)

select * from cst_int2
    join cst_int8 using(a)
    join cst_int4 using(a);
 a  
----
 10
(1 row)

reset optimizer_join_order;
-- Confirm that the same logic is correct for other join types
explain (verbose) select * from cst_int2 full join cst_int4 using(a);
                                            QUERY PLAN                                            
--------------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)  (cost=756.25..310443.83 rows=9851490 width=4)
   Output: (COALESCE((cst_int2.a)::integer, cst_int4.a))
   ->  Hash Full Join  (cost=756.25..179090.62 rows=3283830 width=4)
         Output: COALESCE((cst_int2.a)::integer, cst_int4.a)
         Hash Cond: (cst_int2.a = cst_int4.a)
         ->  Seq Scan on public.cst_int2  (cost=0.00..375.00 rows=34100 width=2)
               Output: cst_int2.a
         ->  Hash  (cost=355.00..355.00 rows=32100 width=4)
               Output: cst_int4.a
               ->  Seq Scan on public.cst_int4  (cost=0.00..355.00 rows=32100 width=4)
                     Output: cst_int4.a
 Optimizer: Postgres-based planner
 Settings: optimizer = 'off', optimizer_enable_mergejoin = 'off', optimizer_enable_nljoin = 'off'
(13 rows)

