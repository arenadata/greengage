-- Here, insead of an implicit cast, an explicit one is present.
--    The postgres-based planner should require a redistribution, because
--    distribution of the cst_int2 table is not directly equal to the left-hand side of the expression
--    ORCA, on the other hand, can see that redistribution is unnecessary in this case
explain (verbose) select * from cst_int2 join cst_int4 on cst_int2.a::int4 = cst_int4.a;
                                    QUERY PLAN                                     
-----------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)  (cost=0.00..862.00 rows=1 width=6)
   Output: cst_int2.a, cst_int4.a
   ->  Hash Join  (cost=0.00..862.00 rows=1 width=6)
         Output: cst_int2.a, cst_int4.a
         Hash Cond: (cst_int4.a = (cst_int2.a)::integer)
         ->  Seq Scan on public.cst_int4  (cost=0.00..431.00 rows=1 width=4)
               Output: cst_int4.a
         ->  Hash  (cost=431.00..431.00 rows=1 width=2)
               Output: cst_int2.a
               ->  Seq Scan on public.cst_int2  (cost=0.00..431.00 rows=1 width=2)
                     Output: cst_int2.a
 Optimizer: GPORCA
 Settings: optimizer_enable_mergejoin = 'off', optimizer_enable_nljoin = 'off'
(13 rows)

select * from cst_int2 join cst_int4 on cst_int2.a::int4 = cst_int4.a;
