-- Confirm that casting logic works recursively
explain (verbose)
select * from cst_int2
    join cst_int8 using(a)
    join cst_int4 using(a);
                                                  QUERY PLAN                                                   
---------------------------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)  (cost=0.00..1293.00 rows=1 width=8)
   Output: cst_int8.a
   ->  Hash Join  (cost=0.00..1293.00 rows=1 width=8)
         Output: cst_int8.a
         Hash Cond: (cst_int8.a = (cst_int4.a)::bigint)
         ->  Hash Join  (cost=0.00..862.00 rows=1 width=8)
               Output: cst_int8.a
               Hash Cond: ((cst_int2.a)::bigint = cst_int8.a)
               ->  Seq Scan on public.cst_int2  (cost=0.00..431.00 rows=1 width=2)
                     Output: cst_int2.a
               ->  Hash  (cost=431.00..431.00 rows=1 width=8)
                     Output: cst_int8.a
                     ->  Seq Scan on public.cst_int8  (cost=0.00..431.00 rows=1 width=8)
                           Output: cst_int8.a
         ->  Hash  (cost=431.00..431.00 rows=1 width=4)
               Output: cst_int4.a
               ->  Seq Scan on public.cst_int4  (cost=0.00..431.00 rows=1 width=4)
                     Output: cst_int4.a
 Optimizer: GPORCA
 Settings: optimizer_enable_mergejoin = 'off', optimizer_enable_nljoin = 'off', optimizer_join_order = 'query'
(20 rows)

select * from cst_int2
    join cst_int8 using(a)
    join cst_int4 using(a);
 a  
----
 10
(1 row)

reset optimizer_join_order;
-- Confirm that the same logic is correct for other join types
