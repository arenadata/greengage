-- Confirm that casting logic works recursively
explain (verbose, costs off)
select * from cst_int2
    join cst_int8 using(a)
    join cst_int4 using(a);
                                                  QUERY PLAN                                                   
---------------------------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)
   Output: cst_int8.a
   ->  Hash Join
         Output: cst_int8.a
         Hash Cond: (cst_int8.a = (cst_int4.a)::bigint)
         ->  Hash Join
               Output: cst_int8.a
               Hash Cond: ((cst_int2.a)::bigint = cst_int8.a)
               ->  Seq Scan on public.cst_int2
                     Output: cst_int2.a
               ->  Hash
                     Output: cst_int8.a
                     ->  Seq Scan on public.cst_int8
                           Output: cst_int8.a
         ->  Hash
               Output: cst_int4.a
               ->  Seq Scan on public.cst_int4
                     Output: cst_int4.a
 Optimizer: GPORCA
 Settings: optimizer_enable_mergejoin = 'off', optimizer_enable_nljoin = 'off', optimizer_join_order = 'query'
(20 rows)

select * from cst_int2
    join cst_int8 using(a)
    join cst_int4 using(a);
 a  
----
 10
(1 row)

reset optimizer_join_order;
-- Confirm that the same logic is correct for other join types
explain (verbose, costs off) select * from cst_int2 full join cst_int4 using(a);
                                  QUERY PLAN                                   
-------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)
   Output: (COALESCE((cst_int2.a)::integer, cst_int4.a))
   ->  Hash Full Join
         Output: COALESCE((cst_int2.a)::integer, cst_int4.a)
         Hash Cond: (cst_int4.a = (cst_int2.a)::integer)
         ->  Seq Scan on public.cst_int4
               Output: cst_int4.a
         ->  Hash
               Output: cst_int2.a
               ->  Seq Scan on public.cst_int2
                     Output: cst_int2.a
 Optimizer: GPORCA
 Settings: optimizer_enable_mergejoin = 'off', optimizer_enable_nljoin = 'off'
(13 rows)

