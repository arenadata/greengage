--
-- Test for parallelizing function scans. 
--
DROP TABLE IF EXISTS intab CASCADE;
NOTICE:  table "intab" does not exist, skipping
 CREATE TABLE intab (
   id int8 primary key,
   data int8);
INSERT INTO intab values (1,1),(2,4),(3,9),(4,16),(5,25),(6,36),(7,49),(8,64);
DROP TABLE IF EXISTS few CASCADE;
NOTICE:  table "few" does not exist, skipping
CREATE TABLE few(id int, dataa text, datab text);
NOTICE:  Table doesn't have 'DISTRIBUTED BY' clause -- Using column named 'id' as the Greengage Database data distribution key for this table.
HINT:  The 'DISTRIBUTED BY' clause determines the distribution of data. Make sure column(s) chosen are the optimal data distribution key to minimize skew.
INSERT INTO few VALUES(1, 'a', 'foo'),(2, 'a', 'bar'),(3, 'b', 'bar');
-- Function which accesses distributed table
CREATE OR REPLACE FUNCTION readtab(int) RETURNS SETOF intab 
EXECUTE ON INITPLAN
AS
$$
DECLARE 
r intab%rowtype;
BEGIN
  FOR r IN SELECT * FROM intab WHERE id < $1 ORDER BY id LOOP
      return next r;
  end loop;
  RETURN;
END
$$ LANGUAGE plpgsql;
-- Functions which depends on its arguemts only
CREATE OR REPLACE FUNCTION genrecs(int) RETURNS SETOF intab IMMUTABLE AS
$$
DECLARE r intab%rowtype;
        i int;
BEGIN
	FOR i in 1..$1 LOOP
		r.id=i;
		r.data=i*i;
		RETURN NEXT r;
	END LOOP;
	RETURN;
END;
$$ LANGUAGE plpgsql;
-- function which accesses master-only table
CREATE OR REPLACE  FUNCTION masteronly(int) RETURNS SETOF intab 
STABLE
EXECUTE ON MASTER AS
$$
DECLARE r intab%rowtype;
        i int;
BEGIN
	FOR i in select dbid FROM gp_segment_configuration WHERE dbid <= $1
	ORDER BY dbid
	LOOP
		r.id=i;
		r.data=i*i;
		RETURN NEXT r;
	END LOOP;
	RETURN;
END;
$$ LANGUAGE plpgsql;
-- simple correlated query
SELECT few.id, a.data FROM genrecs(8) a,few WHERE a.id = few.id;
 id | data 
----+------
  2 |    4
  3 |    9
  1 |    1
(3 rows)

EXPLAIN SELECT few.id, a.data FROM genrecs(8) a,few  WHERE a.id = few.id;
                                  QUERY PLAN                                   
-------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)  (cost=2.32..16.17 rows=10 width=12)
   ->  Hash Join  (cost=2.32..16.17 rows=4 width=12)
         Hash Cond: (a.id = few.id)
         ->  Function Scan on genrecs a  (cost=0.25..10.25 rows=334 width=16)
         ->  Hash  (cost=2.03..2.03 rows=1 width=4)
               ->  Seq Scan on few  (cost=0.00..2.03 rows=1 width=4)
 Optimizer: Postgres query optimizer
(7 rows)

SELECT few.id, a.data FROM masteronly(8) a,few WHERE a.id = few.id;
 id | data 
----+------
  2 |    4
  3 |    9
  1 |    1
(3 rows)

EXPLAIN SELECT few.id, a.data FROM masteronly(8) a,few WHERE a.id = few.id;
                                       QUERY PLAN                                       
----------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice2; segments: 3)  (cost=2.32..36.17 rows=10 width=12)
   ->  Hash Join  (cost=2.32..36.17 rows=4 width=12)
         Hash Cond: (a.id = few.id)
         ->  Redistribute Motion 1:3  (slice1)  (cost=0.25..30.25 rows=1000 width=16)
               Hash Key: a.id
               ->  Function Scan on masteronly a  (cost=0.25..10.25 rows=1000 width=16)
         ->  Hash  (cost=2.03..2.03 rows=1 width=4)
               ->  Seq Scan on few  (cost=0.00..2.03 rows=1 width=4)
 Optimizer: Postgres query optimizer
(9 rows)

SELECT few.id, a.data FROM readtab(8) a,few WHERE a.id = few.id;
 id | data 
----+------
  2 |    4
  3 |    9
  1 |    1
(3 rows)

-- query which is correlated via limit
SELECT (SELECT data FROM genrecs(8) LIMIT 1 OFFSET few.id) FROM few;
 data 
------
    9
   16
    4
(3 rows)

EXPLAIN SELECT (SELECT data FROM genrecs(8) LIMIT 1 OFFSET few.id) FROM few;
                                    QUERY PLAN                                     
-----------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)  (cost=0.00..5.81 rows=3 width=4)
   ->  Seq Scan on few  (cost=0.00..5.81 rows=1 width=4)
         SubPlan 1  (slice1; segments: 1)
           ->  Limit  (cost=1.25..1.26 rows=1 width=8)
                 ->  Function Scan on genrecs  (cost=0.25..10.25 rows=334 width=8)
 Optimizer: Postgres query optimizer
(6 rows)

SELECT (SELECT data FROM masteronly(8) LIMIT 1 OFFSET few.id) FROM few;
 data 
------
    4
    9
   16
(3 rows)

EXPLAIN SELECT (SELECT data FROM masteronly(8) LIMIT 1 OFFSET few.id) FROM few;
                                               QUERY PLAN                                                
---------------------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice2; segments: 3)  (cost=0.00..5.81 rows=3 width=4)
   ->  Seq Scan on few  (cost=0.00..5.81 rows=1 width=4)
         SubPlan 1  (slice2; segments: 3)
           ->  Limit  (cost=1.25..1.26 rows=1 width=8)
                 ->  Result  (cost=0.25..15.25 rows=1000 width=8)
                       ->  Materialize  (cost=0.25..15.25 rows=1000 width=8)
                             ->  Broadcast Motion 1:3  (slice1)  (cost=0.25..10.25 rows=1000 width=8)
                                   ->  Function Scan on masteronly  (cost=0.25..10.25 rows=1000 width=8)
 Optimizer: Postgres query optimizer
(9 rows)

SELECT (SELECT data FROM readtab(8) LIMIT 1 OFFSET few.id) FROM few;
 data 
------
    9
   16
    4
(3 rows)

EXPLAIN SELECT (SELECT data FROM readtab(8) LIMIT 1 OFFSET few.id) FROM few;
                                                   QUERY PLAN                                                   
----------------------------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice2; segments: 3)  (cost=0.00..5.81 rows=3 width=4)
   ->  Seq Scan on few  (cost=0.00..5.81 rows=1 width=4)
         SubPlan 2  (slice2; segments: 3)
           ->  Limit  (cost=1.25..1.26 rows=1 width=8)
                 InitPlan 1 (returns $1)  (slice3)
                   ->  Function Scan on readtab  (cost=0.25..10.25 rows=1000 width=8)
                 ->  Result  (cost=0.25..15.25 rows=1000 width=8)
                       ->  Materialize  (cost=0.25..15.25 rows=1000 width=8)
                             ->  Broadcast Motion 1:3  (slice1)  (cost=0.25..10.25 rows=1000 width=8)
                                   ->  Function Scan on readtab readtab_1  (cost=0.25..10.25 rows=1000 width=8)
 Optimizer: Postgres query optimizer
(11 rows)

DROP TABLE intab CASCADE;
NOTICE:  drop cascades to 3 other objects
DETAIL:  drop cascades to function readtab(integer)
drop cascades to function genrecs(integer)
drop cascades to function masteronly(integer)
DROP TABLE few CASCADE;
