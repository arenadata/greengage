<?xml version="1.0" encoding="UTF-8"?>
<dxl:DXLMessage xmlns:dxl="http://greengagedb.org/dxl/2010/12/">
  <dxl:Comment><![CDATA[

  Objective: Ensure that NLJ with constant true scalar properly projects
  columns if they are needed on outer levels. 
  It should not fail during translation to DXL with missing projected attribute
  error.

  CREATE TABLE t1 (
    text_t1 text,
    int_t1 integer
  ) DISTRIBUTED BY (int_t1);
  CREATE TABLE t2 (
    text_t2 text,
    int_t2 integer
  ) DISTRIBUTED BY (int_t2);

  INSERT INTO t1 SELECT '0', generate_series (0,1);
  INSERT INTO t2 SELECT '0', generate_series (0,1);
  INSERT INTO t1 SELECT '1', generate_series (0,1);

  SELECT disable_xform('CXformImplementInnerJoin');
  explain SELECT * FROM t1 WHERE 
  (SELECT int_t1 FROM t1 LIMIT 1) 
    NOT IN 
  (SELECT int_t2 FROM t2 WHERE int_t2 = int_t1 OR t1.text_t1 = '0');
                                                QUERY PLAN                                              
  ------------------------------------------------------------------------------------------------------
  Gather Motion 3:1  (slice1; segments: 3)  (cost=0.00..883119.03 rows=1 width=4)
    ->  Hash Left Anti Semi (Not-In) Join  (cost=0.00..883119.03 rows=1 width=4)
          Hash Cond: (t1.a = (NULL::integer))
          ->  Seq Scan on t1  (cost=0.00..431.00 rows=1 width=4)
          ->  Hash  (cost=882688.03..882688.03 rows=1 width=4)
                ->  Broadcast Motion 3:3  (slice2; segments: 3)  (cost=0.00..882688.03 rows=1 width=4)
                      ->  Nested Loop  (cost=0.00..882688.03 rows=1 width=4)
                            Join Filter: true
                            ->  Seq Scan on t1 t1_1  (cost=0.00..431.00 rows=1 width=1)
                            ->  Result  (cost=0.00..0.00 rows=0 width=4)
                                  One-Time Filter: false
  Optimizer: Pivotal Optimizer (GPORCA)
  (12 rows)
  ]]>
  </dxl:Comment>
